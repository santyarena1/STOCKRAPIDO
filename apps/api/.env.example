# Copiá este archivo a .env y completá los valores (opcional si ya configurás todo en la app:
# Configuración → Compras con IA).
# La API carga .env automáticamente (no subas .env al repo).

# URL del webhook de ENTRADA en N8N (también editable en Configuración → Compras con IA).
N8N_INVOICE_WEBHOOK_URL=

# Secreto del callback (también en Configuración). N8N lo envía en X-Webhook-Secret.
AI_INVOICE_WEBHOOK_SECRET=

# URL pública de esta API (callback en el payload). También en Configuración.
PUBLIC_API_URL=http://localhost:4002

PORT=4002

# Sesión: por defecto 365 días (access y refresh). Ejemplos: 90d, 365d, 10y
# JWT_ACCESS_EXPIRES=365d
# JWT_REFRESH_EXPIRES=365d
