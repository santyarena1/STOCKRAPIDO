# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockrapido?schema=public"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-in-production-min-32-chars-refresh"

# App
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

# Email (dev: Mailhog)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@stockrapido.local"

# Seed (crear usuario owner de prueba)
SEED_TEST_EMAIL="owner@demo.com"
SEED_TEST_PASSWORD="Demo123!"

# Vercel Blob (subida de imágenes: logos, QR, fotos de productos, promos)
# Crear un Blob store en Vercel Dashboard → Storage → Create Store → linkear al proyecto web
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Fiscal credential encryption (32 random bytes in base64).
FISCAL_ENCRYPTION_KEY=""
